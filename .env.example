# ==============================================================================
# PixConvert - Environment Variables Template
# Copy this file to '.env' and fill in the actual values.
# Note: All variables prefixed with 'VITE_' will be exposed to the client-side.
# ==============================================================================

# --- Application Core ---
VITE_APP_TITLE=PixConvert
VITE_APP_ENV=development
VITE_APP_VERSION=1.0.0

# --- API & Backend Configuration ---
# Base URL for the backend API (uncomment and set if features are moved server-side)
VITE_API_URL=http://localhost:3000/api/v1

# --- Features & Feature Flags ---
VITE_ENABLE_DEBUG_MODE=false
VITE_ENABLE_ANALYTICS=false

# --- File Upload & Conversion Limits ---
# Maximum allowed file size for conversion (in bytes) - e.g., 10MB = 10485760
VITE_MAX_FILE_SIZE=10485760
# Comma-separated list of allowed source formats
VITE_ALLOWED_INPUT_FORMATS=image/jpeg,image/png,image/webp,image/avif

# --- Third-Party Integrations (Optional) ---
# Example: Client key for error tracking (Sentry / LogRocket)
VITE_SENTRY_DSN=
# Example: Google Analytics ID
VITE_GA_TRACKING_ID=
